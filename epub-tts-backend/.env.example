# ============================================
# DeepReader Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ---------- Database ----------
DATABASE_URL=postgresql://user:password@localhost:5432/deepreader

# ---------- JWT Secret ----------
# Used for signing auth tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=your-secret-key-change-in-production

# ---------- API Key Encryption ----------
# Used for encrypting user's AI API keys. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ---------- SMTP (Email Verification) ----------
# Gmail example:
#   1. Enable 2-Step Verification on your Google account
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-char app password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your@gmail.com

# ---------- App URL ----------
# Frontend URL used in verification email links
APP_URL=https://deepkb.com.cn

# ---------- Guest Account ----------
# Email of the shared guest account (register it first, then set here)
GUEST_EMAIL=guest@deepkb.com.cn

# ---------- TTS (Optional) ----------
ELEVENLABS_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
DATA_DIR=data
