# ============================================
# DeepReader Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ---------- Agent Server (A2A) ----------
# Backend 调用 agent-server 的地址
# Docker 环境用: http://agent-server:9000
# 本地开发用:   http://localhost:9000
AGENT_SERVER_URL=http://agent-server:9000

# ---------- Database ----------
DATABASE_URL=postgresql://user:password@localhost:5432/deepreader

# ---------- JWT Secret ----------
# Used for signing auth tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=your-secret-key-change-in-production

# ---------- API Key Encryption ----------
# Used for encrypting user's AI API keys. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ---------- Guest Account ----------
# Email of the shared guest account (register it first, then set here)
GUEST_EMAIL=guest@deepkb.com.cn

# ---------- Concept Extraction ----------
# Provider type: anthropic | openai-chat | openai-compatible
CONCEPT_LLM_PROVIDER_TYPE=anthropic
CONCEPT_LLM_API_KEY=
CONCEPT_LLM_BASE_URL=https://api.minimaxi.com/anthropic
CONCEPT_LLM_MODEL=MiniMax-M2.7

CONCEPT_EMBED_API_KEY=
CONCEPT_EMBED_BASE_URL=https://model-square.app.baizhi.cloud/v1/embeddings
CONCEPT_EMBED_MODEL=bge-m3

# ---------- TTS (Optional) ----------
ELEVENLABS_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
DATA_DIR=data
