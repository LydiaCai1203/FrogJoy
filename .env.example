# ===========================
# Database
# ===========================
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/bookreader

# ===========================
# Security
# ===========================
JWT_SECRET_KEY=change-me-in-production
FERNET_KEY=change-me-in-production

# ===========================
# Redis
# ===========================
REDIS_URL=redis://localhost:6379/0

# ===========================
# TTS
# ===========================
ELEVENLABS_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com

# ===========================
# Concept Extraction - LLM
# ===========================
# 支持任意 Anthropic 兼容端点 (MiniMax / Kimi / Claude 等)
# provider_type: "anthropic" | "openai-chat"
CONCEPT_LLM_API_KEY=
CONCEPT_LLM_BASE_URL=https://api.minimaxi.com/anthropic
CONCEPT_LLM_MODEL=MiniMax-M2.7

# ===========================
# Concept Extraction - Embedding
# ===========================
CONCEPT_EMBED_API_KEY=
CONCEPT_EMBED_BASE_URL=https://model-square.app.baizhi.cloud/v1/embeddings
CONCEPT_EMBED_MODEL=bge-m3

# ===========================
# SMTP (邮件)
# ===========================
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ===========================
# App
# ===========================
APP_URL=https://deepkb.com.cn
DATA_DIR=data
HOST=0.0.0.0
PORT=8000
AGENT_SERVER_URL=http://agent-server:9000
